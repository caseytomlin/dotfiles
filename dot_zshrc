typeset -ga _workspace_dotenv_loaded_keys=()

_workspace_dotenv_unload() {
    local key

    for key in "${_workspace_dotenv_loaded_keys[@]}"; do
        unset "$key"
    done

    _workspace_dotenv_loaded_keys=()
}

_workspace_dotenv_load_file() {
    local file="$1"
    local line key value

    [[ -f "$file" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"
        [[ -z "$line" || "$line" == \#* ]] && continue
        line="${line#export }"
        [[ "$line" == *=* ]] || continue

        key="${line%%=*}"
        value="${line#*=}"

        [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue

        if [[ "$value" == \"*\" && "$value" == *\" ]]; then
            value="${value:1:${#value}-2}"
        elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
            value="${value:1:${#value}-2}"
        fi

        if [[ -z "${(P)key:-}" ]]; then
            export "$key=$value"
            _workspace_dotenv_loaded_keys+=("$key")
        fi
    done < "$file"

    return 0
}

_workspace_dotenv_refresh() {
    local candidate

    _workspace_dotenv_unload

    for candidate in "$PWD/.env.local" "$PWD/.env"; do
        _workspace_dotenv_load_file "$candidate" && return 0
    done

    return 0
}

chpwd_functions+=(_workspace_dotenv_refresh)
_workspace_dotenv_refresh

# Sync ECA my-gen-assist model map from claude-code-router models
ccr-sync-eca-models() {
    local router_config="$HOME/.claude-code-router/config.json"
    local eca_config="$HOME/.config/eca/config.json"

    if [ ! -f "$router_config" ]; then
        echo "ccr-sync-eca-models: router config not found at $router_config" >&2
        return 1
    fi
    if [ ! -f "$eca_config" ]; then
        echo "ccr-sync-eca-models: eca config not found at $eca_config" >&2
        return 1
    fi

    local models_json
    models_json=$(jq -c '[
        .Providers[]?
        | select(.name == "myGenAssist" or .name == "my-gen-assist")
        | .models[]?
        | select(type == "string" and length > 0)
    ] | unique | sort' "$router_config" 2>/dev/null)

    if [ -z "$models_json" ] || [ "$models_json" = "[]" ]; then
        echo "ccr-sync-eca-models: no router models found, eca config unchanged" >&2
        return 1
    fi

    local model_count tmp
    model_count=$(echo "$models_json" | jq 'length')
    tmp=$(mktemp)

    jq --argjson models "$models_json" '
      .providers["my-gen-assist"].models =
        (reduce $models[] as $m ({}; . + {($m): {}}))
    ' "$eca_config" > "$tmp" && mv "$tmp" "$eca_config"

    echo "ccr-sync-eca-models: synced ${model_count} models to $eca_config"
}

# Refresh claude-code-router model list from myGenAssist API
ccr-refresh() {
    local config="$HOME/.claude-code-router/config.json"
    if [ ! -f "$config" ]; then
        echo "ccr-refresh: config not found at $config" >&2
        return 1
    fi
    if [ -z "${MGA_API_KEY:-}" ]; then
        echo "ccr-refresh: MGA_API_KEY is not set" >&2
        return 1
    fi
    local model_ids
    model_ids=$(curl -sf -H "Authorization: Bearer $MGA_API_KEY"         https://chat.int.bayer.com/api/v2/models | jq -r '.data[].id' 2>/dev/null)
    if [ -z "$model_ids" ]; then
        echo "ccr-refresh: model fetch returned no results, config unchanged" >&2
        return 1
    fi
    local claude_models primary_model
    claude_models=$(echo "$model_ids" | grep 'claude' | grep -v 'azure' | sort -V)
    primary_model=$(echo "$claude_models" | tail -n1)
    [ -z "$primary_model" ] && primary_model=$(echo "$model_ids" | head -n1)
    local tmp
    tmp=$(mktemp)
    jq --argjson models "$(echo "$model_ids" | jq -R . | jq -s .)"        --arg primary "$primary_model"        '.Providers[0].models = $models | .Router.default = "myGenAssist,\($primary)"'        "$config" > "$tmp" && mv "$tmp" "$config"
    echo "ccr-refresh: $(echo "$model_ids" | wc -l | tr -d ' ') models, default: $primary_model"

    # Keep ECA model picker aligned with router models.
    ccr-sync-eca-models || echo "ccr-refresh: warning: could not sync ECA models" >&2
}
